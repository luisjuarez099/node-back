generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  passwd       String
  role         Role
  appointments Appointment[]
}

model Appointment {
  id          Int       @id @default(autoincrement())
  date        DateTime
  user        User      @relation(fields: [userId], references: [id])
  userId      Int
  timeBlock   TimeBlock @relation(fields: [timeBlockId], references: [id])
  timeBlockId Int
}

model TimeBlock {
  id           Int           @id @default(autoincrement())
  startTime    DateTime
  endTime      DateTime
  appointments Appointment[]
}
